#:import layout_exemples layout_exemples
#:import widget_exemples widget_exemples
#:import navigation_screen_manager navigation_screen_manager


MyScreenManager:


<MyScreenManager@NavigationScreenManager>:
    Screen:
        name: "screen1"
        BoxLayout:
            Button:
                text: "aller vers écran 2"
                on_press: root.push("screen2")
            Button:
                text: "aller vers écran 3"
                on_press: root.push("screen3")

    Screen:
        name: "screen2"
        Button:
            text: "Button2"
            on_press: root.pop()

    Screen:
        name: "screen3"
        Button:
            text: "Button3"
            on_press: root.pop()



        
            

