#:import layout_exemples layout_exemples
#:import widget_exemples widget_exemples
#:import navigation_screen_manager navigation_screen_manager
#:import boxlayout_with_action_bar boxlayout_with_action_bar




<MyScreenManager>:
    Screen:
        name: "screen1"
        BoxLayout:
            Button:
                text: "aller vers écran Images"
                on_press: app.manager.push("ImagesExemple")
            Button:
                text: "aller vers écran 3"
                on_press: app.manager.push("screen3")
    Screen:
        name: "ImagesExemple"
        BoxLayoutWithActionBar:
            title: "Images"
            ImagesExemple:
    Screen:
        name: "screen2"
        Button:
            text: "Button2"
            on_press: app.manager.pop()

    Screen:
        name: "screen3"
        Button:
            text: "Button3"
            on_press: app.manager.pop()



        
            

