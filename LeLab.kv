        # height: "60dp"
        # x, right, center_x
        # y, top, center_y
        pos_hint: {"top": 1}
    Button:
        text: "B"
    Button:
        text: "C"


<MainWidget>:
    Button:
        text: "Hello"
        size: "100dp", "60dp"
        pos:  "200dp", "100dp"
        color: 0, 0, 1, 1
    Label:
        text: "Hello2"
        size: "100dp", "60dp"
        pos:  "400dp", "200dp"
        color: 1, 0, 0, 1